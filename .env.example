# Nenya environment variables
# For full configuration, copy nenya.yaml.default to nenya.yaml
# These env vars are referenced by nenya.yaml via ${VAR} syntax.

# API keys (secrets, keep in .env)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
API_KEY=

# Database (can also be set in nenya.yaml)
DATABASE_URL=postgresql://nenya:nenya@localhost:5432/nenya
